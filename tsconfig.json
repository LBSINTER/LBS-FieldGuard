{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-native",
    "baseUrl": ".",
    "paths": {
      "@scanner/*": ["src/scanner/*"],
      "@network/*": ["src/network/*"],
      "@probe/*": ["src/probe/*"],
      "@android/*": ["src/android/*"],
      "@ss7/*": ["src/ss7/*"],
      "@ui/*": ["src/ui/*"],
      "@store/*": ["src/store/*"],
      "@types/*": ["src/types/*"],
      "@utils/*": ["src/utils/*"]
    }
  },
  "exclude": ["node_modules", "android", "windows", "__tests__/native"]
}
