{
  "name": "LBSFieldGuard",
  "version": "1.0.0",
  "private": true,
  "description": "LBS FieldGuard — Multi-platform mobile forensics and SS7 threat detection",
  "scripts": {
    "android": "react-native run-android",
    "windows": "react-native run-windows",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:windows": "react-native run-windows --release",
    "apk": "cd android && ./gradlew assembleRelease && echo 'APK: android/app/build/outputs/apk/release/app-release.apk'"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.22.2",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.10",
    "@react-navigation/stack": "^6.3.20",
    "asmcrypto.js": "^2.3.2",
    "axios": "^1.6.7",
    "buffer": "^6.0.3",
    "events": "^3.3.0",
    "react": "18.2.0",
    "react-native": "0.73.4",
    "react-native-chart-kit": "^6.12.0",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.14.1",
    "react-native-permissions": "^4.1.5",
    "react-native-safe-area-context": "^4.8.2",
    "react-native-screens": "3.29.0",
    "react-native-svg": "^14.1.0",
    "react-native-tcp-socket": "^6.0.6",
    "react-native-vector-icons": "^10.0.3",
    "react-native-windows": "0.73.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/babel-preset": "^0.73.21",
    "@react-native/eslint-config": "^0.73.2",
    "@react-native/metro-config": "^0.73.4",
    "@react-native/typescript-config": "^0.73.1",
    "@types/react": "^18.2.6",
    "@types/react-native": "^0.73.0",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.6.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "18.2.0",
    "typescript": "5.0.4"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
